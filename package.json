{
  "name": "vibe-design-system-kit",
  "version": "0.1.0",
  "private": true,
  "description": "A portable, AI-friendly design system for B2B / data-heavy web products. Give it one brand color and it derives a full coherent theme — brand ramp, neutrals, an 11-color chart palette, and shadcn/ui tokens.",
  "keywords": [
    "design-system",
    "design-tokens",
    "theme",
    "theming",
    "tailwindcss",
    "shadcn-ui",
    "nextjs",
    "react",
    "echarts",
    "ai",
    "cursor",
    "claude-code"
  ],
  "license": "MIT",
  "author": "LeonAgents",
  "homepage": "https://github.com/LeonAgents/vibe-design-system-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeonAgents/vibe-design-system-kit.git"
  },
  "bugs": {
    "url": "https://github.com/LeonAgents/vibe-design-system-kit/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint && npm run theme:check",
    "lint:fix": "eslint --fix",
    "theme:check": "node scripts/check-theme-tokens.mjs",
    "theme:new": "node scripts/generate-theme.mjs",
    "tokens:build": "node --experimental-strip-types scripts/build-tokens-css.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "echarts-wordcloud": "^2.1.0",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
