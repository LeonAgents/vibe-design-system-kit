{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/LeonAgents/vibe-design-system-kit/schemas/app-theme.schema.json",
  "title": "AppTheme",
  "description": "Vibe 设计系统的主题契约。对应 src/themes/types.ts。AI 生成主题时输出必须满足此 schema。",
  "type": "object",
  "required": ["id", "name", "description", "tokens"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$", "description": "kebab-case 唯一标识，如 default / tech-blue。" },
    "name": { "type": "string", "description": "人读主题名。" },
    "description": { "type": "string", "description": "一句话描述适用场景。" },
    "tokens": {
      "type": "object",
      "required": [
        "background", "border", "text", "brand", "notification", "indicator",
        "risk", "status", "sentiment", "chart", "typography", "radius",
        "spacing", "shadow", "overlay", "link", "accent", "component", "shadcn"
      ],
      "additionalProperties": false,
      "properties": {
        "background": {
          "type": "object",
          "required": ["primary", "secondary", "card", "cardHover", "selected", "control"],
          "additionalProperties": false,
          "properties": {
            "primary": { "$ref": "#/$defs/color" },
            "secondary": { "$ref": "#/$defs/color" },
            "card": { "$ref": "#/$defs/color" },
            "cardHover": { "$ref": "#/$defs/color" },
            "selected": { "$ref": "#/$defs/color" },
            "control": { "$ref": "#/$defs/color" }
          }
        },
        "border": {
          "type": "object",
          "required": ["divider"],
          "additionalProperties": false,
          "properties": { "divider": { "$ref": "#/$defs/color" } }
        },
        "text": {
          "type": "object",
          "required": ["strong", "regular", "secondary", "decorative", "disabled", "inverse"],
          "additionalProperties": false,
          "properties": {
            "strong": { "$ref": "#/$defs/color" },
            "regular": { "$ref": "#/$defs/color" },
            "secondary": { "$ref": "#/$defs/color" },
            "decorative": { "$ref": "#/$defs/color" },
            "disabled": { "$ref": "#/$defs/color" },
            "inverse": { "$ref": "#/$defs/color" }
          }
        },
        "brand": {
          "type": "object",
          "required": ["primary", "hover", "active", "foreground", "light", "rgb"],
          "additionalProperties": false,
          "properties": {
            "primary": { "$ref": "#/$defs/color" },
            "hover": { "$ref": "#/$defs/color", "description": "比 primary 略暗、略降饱和。" },
            "active": { "$ref": "#/$defs/color", "description": "比 hover 更暗、更降饱和。" },
            "foreground": { "$ref": "#/$defs/color", "description": "品牌色上的文字色；浅色品牌用深字，深色品牌用反白。" },
            "light": { "type": "string", "description": "品牌色低透明度版本，如 rgba(r,g,b,0.08)。" },
            "rgb": { "type": "string", "pattern": "^\\d{1,3},\\s*\\d{1,3},\\s*\\d{1,3}$", "description": "品牌色 RGB 分量，如 79, 70, 229。" }
          }
        },
        "notification": {
          "type": "object", "required": ["badge"], "additionalProperties": false,
          "properties": { "badge": { "$ref": "#/$defs/color" } }
        },
        "indicator": {
          "type": "object", "required": ["up", "down"], "additionalProperties": false,
          "properties": { "up": { "$ref": "#/$defs/color" }, "down": { "$ref": "#/$defs/color" } }
        },
        "risk": {
          "type": "object", "required": ["high", "medium", "low"], "additionalProperties": false,
          "properties": { "high": { "$ref": "#/$defs/color" }, "medium": { "$ref": "#/$defs/color" }, "low": { "$ref": "#/$defs/color" } }
        },
        "status": {
          "type": "object", "required": ["success", "warning", "danger", "info"], "additionalProperties": false,
          "properties": {
            "success": { "$ref": "#/$defs/color" }, "warning": { "$ref": "#/$defs/color" },
            "danger": { "$ref": "#/$defs/color" }, "info": { "$ref": "#/$defs/color" }
          }
        },
        "sentiment": {
          "type": "object", "required": ["positive", "neutral", "negative"], "additionalProperties": false,
          "properties": {
            "positive": { "$ref": "#/$defs/color" }, "neutral": { "$ref": "#/$defs/color" }, "negative": { "$ref": "#/$defs/color" }
          }
        },
        "chart": {
          "type": "array",
          "description": "图表多色板，恰好 11 色，低饱和、跨色相、互相和谐。",
          "minItems": 11,
          "maxItems": 11,
          "items": { "$ref": "#/$defs/color" }
        },
        "typography": {
          "type": "object",
          "required": ["fontSans", "fontDisplay", "fontData", "bodyFontSize", "bodyLineHeight"],
          "additionalProperties": false,
          "properties": {
            "fontSans": { "type": "string" },
            "fontDisplay": { "type": "string" },
            "fontData": { "type": "string" },
            "bodyFontSize": { "type": "string", "description": "正文字号，建议 ≥14px。" },
            "bodyLineHeight": { "type": "string" }
          }
        },
        "radius": {
          "type": "object",
          "required": ["xs", "sm", "md", "lg", "xl", "full"],
          "additionalProperties": false,
          "properties": {
            "xs": { "$ref": "#/$defs/size" }, "sm": { "$ref": "#/$defs/size" }, "md": { "$ref": "#/$defs/size" },
            "lg": { "$ref": "#/$defs/size" }, "xl": { "$ref": "#/$defs/size" }, "full": { "$ref": "#/$defs/size" }
          }
        },
        "spacing": {
          "type": "object",
          "required": ["xxs", "xs", "sm", "md", "base", "lg", "xl", "xxl", "section", "pageX", "cardPadding"],
          "additionalProperties": false,
          "properties": {
            "xxs": { "$ref": "#/$defs/size" }, "xs": { "$ref": "#/$defs/size" }, "sm": { "$ref": "#/$defs/size" },
            "md": { "$ref": "#/$defs/size" }, "base": { "$ref": "#/$defs/size" }, "lg": { "$ref": "#/$defs/size" },
            "xl": { "$ref": "#/$defs/size" }, "xxl": { "$ref": "#/$defs/size" }, "section": { "$ref": "#/$defs/size" },
            "pageX": { "$ref": "#/$defs/size" }, "cardPadding": { "$ref": "#/$defs/size" }
          }
        },
        "shadow": {
          "type": "object",
          "required": ["none", "card", "cardHover", "popover", "modal"],
          "additionalProperties": false,
          "properties": {
            "none": { "type": "string" }, "card": { "type": "string" }, "cardHover": { "type": "string" },
            "popover": { "type": "string" }, "modal": { "type": "string" }
          }
        },
        "overlay": {
          "type": "object", "required": ["scrim"], "additionalProperties": false,
          "properties": { "scrim": { "type": "string" } }
        },
        "link": {
          "type": "object", "required": ["default", "hover", "muted", "legal"], "additionalProperties": false,
          "properties": {
            "default": { "$ref": "#/$defs/color" }, "hover": { "$ref": "#/$defs/color" },
            "muted": { "$ref": "#/$defs/color" }, "legal": { "$ref": "#/$defs/color" }
          }
        },
        "accent": {
          "type": "object", "required": ["one", "two", "premium", "standard"], "additionalProperties": false,
          "properties": {
            "one": { "$ref": "#/$defs/color" }, "two": { "$ref": "#/$defs/color" },
            "premium": { "$ref": "#/$defs/color" }, "standard": { "$ref": "#/$defs/color" }
          }
        },
        "component": {
          "type": "object",
          "required": ["button", "card", "input", "popover", "modal"],
          "additionalProperties": false,
          "properties": {
            "button": {
              "type": "object", "required": ["radius", "height", "paddingX"], "additionalProperties": false,
              "properties": { "radius": { "$ref": "#/$defs/size" }, "height": { "$ref": "#/$defs/size" }, "paddingX": { "$ref": "#/$defs/size" } }
            },
            "card": {
              "type": "object", "required": ["radius", "padding", "shadow", "hoverShadow"], "additionalProperties": false,
              "properties": { "radius": { "$ref": "#/$defs/size" }, "padding": { "$ref": "#/$defs/size" }, "shadow": { "type": "string" }, "hoverShadow": { "type": "string" } }
            },
            "input": {
              "type": "object", "required": ["radius", "height"], "additionalProperties": false,
              "properties": { "radius": { "$ref": "#/$defs/size" }, "height": { "$ref": "#/$defs/size" } }
            },
            "popover": {
              "type": "object", "required": ["radius", "padding", "shadow"], "additionalProperties": false,
              "properties": { "radius": { "$ref": "#/$defs/size" }, "padding": { "$ref": "#/$defs/size" }, "shadow": { "type": "string" } }
            },
            "modal": {
              "type": "object", "required": ["radius", "shadow"], "additionalProperties": false,
              "properties": { "radius": { "$ref": "#/$defs/size" }, "shadow": { "type": "string" } }
            }
          }
        },
        "shadcn": {
          "type": "object",
          "description": "shadcn/ui 兼容 token，全部为 'H S% L%' 空格分隔的 HSL 字符串（不带 hsl() 包裹）。",
          "required": [
            "background", "foreground", "card", "cardForeground", "popover", "popoverForeground",
            "primary", "primaryForeground", "secondary", "secondaryForeground", "muted", "mutedForeground",
            "accent", "accentForeground", "destructive", "destructiveForeground", "border", "input", "ring"
          ],
          "additionalProperties": false,
          "patternProperties": {
            "^[a-zA-Z]+$": { "$ref": "#/$defs/hslTriplet" }
          }
        }
      }
    }
  },
  "$defs": {
    "color": {
      "type": "string",
      "description": "颜色：#RRGGBB / #RGB / rgb() / rgba()。产品 UI 一律不在组件里写死，必须落在主题里。",
      "pattern": "^(#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})|rgb\\(.*\\)|rgba\\(.*\\))$"
    },
    "size": {
      "type": "string",
      "description": "尺寸：带单位的 CSS 长度，如 8px / 1rem / 9999px。",
      "pattern": "^(0|[0-9.]+(px|rem|em|%))$"
    },
    "hslTriplet": {
      "type": "string",
      "description": "'H S% L%'，如 243 75% 59%。",
      "pattern": "^\\d{1,3}(\\.\\d+)?\\s+\\d{1,3}(\\.\\d+)?%\\s+\\d{1,3}(\\.\\d+)?%$"
    }
  }
}
